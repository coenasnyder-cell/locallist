rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Profile photos - allow users to upload their own
    match /profilePhotos/{userId}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null;
    }

    // Business logos - allow users to upload their own
    match /businessLogos/{userId}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read: if true;
    }

    // Shop Local business images - allow users to upload their own
    match /shopLocalImages/{userId}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read: if true;
    }

    // Business claim proof images - allow users to upload their own claim evidence
    match /businessClaimProofs/{userId}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && request.auth.uid == userId;
    }

    // Business verification documents - allow users to upload their own verification files
    match /businessVerificationDocuments/{userId}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && request.auth.uid == userId;
    }

    // Listing images - allow uploads
    match /listingImages/{userId}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read: if true;
    }

    // AI listing reference images - allow signed-in users to upload their own
    match /aiListingReferenceImages/{userId}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read: if true;
    }

    // Pet images - allow users to upload their own
    match /petImages/{userId}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read: if true;
    }

    // Event listing images - allow users to upload their own
    match /eventImages/{userId}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read: if true;
    }

    // Yard sale images - allow users to upload their own
    match /yardSaleImages/{userId}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read: if true;
    }

    // Service listing images - allow users to upload their own
    match /services/{userId}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read: if true;
    }

    // Deny any paths not explicitly covered above.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
