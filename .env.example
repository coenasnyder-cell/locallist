# ─── Environment Configuration ──────────────────────────────────────────
# Copy this file to .env and fill in with your Firebase project credentials
# These variables are injected by EAS during builds based on the build profile
# NOTE: For Expo apps, only EXPO_PUBLIC_* variables are accessible in the app runtime

# ─── DEVELOPMENT Firebase Project ────────────────────────────────────────
# Use a separate Firebase project for development/testing builds
# This prevents test analytics from polluting production data
EXPO_PUBLIC_DEV_FIREBASE_API_KEY=TODO_DEV_API_KEY
EXPO_PUBLIC_DEV_FIREBASE_AUTH_DOMAIN=TODO_DEV_AUTH_DOMAIN
EXPO_PUBLIC_DEV_FIREBASE_PROJECT_ID=TODO_DEV_PROJECT_ID
EXPO_PUBLIC_DEV_FIREBASE_STORAGE_BUCKET=TODO_DEV_STORAGE_BUCKET
EXPO_PUBLIC_DEV_FIREBASE_MESSAGING_SENDER_ID=TODO_DEV_SENDER_ID
EXPO_PUBLIC_DEV_FIREBASE_APP_ID=TODO_DEV_APP_ID
EXPO_PUBLIC_DEV_FIREBASE_MEASUREMENT_ID=TODO_DEV_MEASUREMENT_ID

# ─── PRODUCTION Firebase Project ────────────────────────────────────────
# Your main Firebase project for production builds
EXPO_PUBLIC_PROD_FIREBASE_API_KEY=AIzaSyDGaAN-Fg1mK3KZANo88t__OEoJA8SJAD0
EXPO_PUBLIC_PROD_FIREBASE_AUTH_DOMAIN=local-list-wski21.firebaseapp.com
EXPO_PUBLIC_PROD_FIREBASE_PROJECT_ID=local-list-wski21
EXPO_PUBLIC_PROD_FIREBASE_STORAGE_BUCKET=local-list-wski21.firebasestorage.app
EXPO_PUBLIC_PROD_FIREBASE_MESSAGING_SENDER_ID=280253430618
EXPO_PUBLIC_PROD_FIREBASE_APP_ID=1:280253430618:web:f1110d0f205e619fea9163
EXPO_PUBLIC_PROD_FIREBASE_MEASUREMENT_ID=G-P839RQT0W8

# ─── HOW TO SET UP ────────────────────────────────────────────────────
# 1. Create a new Firebase project for development (if not already created)
#    - Go to Firebase Console: https://console.firebase.google.com
#    - Click "Add Project" → name it something like "myApp-dev"
#    - Enable Firestore, Authentication (Email + Google), and Storage
#
# 2. Get your Firebase credentials:
#    - In Firebase Console, go to Project Settings
#    - Under "Your apps" section, find your Web app
#    - Copy the firebaseConfig object values to this file (DEV section)
#
# 3. Update EAS secrets for CI/CD:
#    - Run: eas secret:create
#    - Create secrets for each EXPO_PUBLIC_* variable above
#    - This ensures secrets are safe when building via EAS
#
# 4. Local development:
#    - Fill in DEV credentials above
#    - Run: eas build --platform android --profile development
#    - This will use DEV Firebase project for testing
#
# 5. Production builds:
#    - PROD credentials are already set (current project)
#    - Run: eas build --platform ios --profile production
#    - This will use PROD Firebase project for live app
