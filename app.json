{
  "expo": {
    "owner": "csnyde2",
    "name": "myApp",
    "slug": "myApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mycompany.locallist",
      "associatedDomains": [
        "applinks:app.locallist.biz"
      ],
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "We need access to your photo library to let you upload a profile picture.",
        "NSLocationWhenInUseUsageDescription": "Local List uses your location once to suggest your ZIP code near Harrison, NJ for local listings and service-area matching. We do not store GPS coordinates on your profile.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.mycompany.locallist",
      "versionCode": 17,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "app.locallist.biz",
              "pathPrefix": "/auth-action"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "com.googleusercontent.apps.280253430618-89ca2lhmi2i1j7eim2sm3pggon01ett0",
              "pathPrefix": "/oauthredirect"
            },
            {
              "scheme": "com.googleusercontent.apps.280253430618-tfe8d05h9ge10c5oitlbkh1upfbu8j6r",
              "pathPrefix": "/oauthredirect"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "build": {
        "babel": {}
      }
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://app.locallist.biz",
          "asyncRoutes": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.280253430618-66bopqe6ob2jj555d764mmmodr3thssr"
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Local List uses your location once to suggest your ZIP code for Harrison-area listings. GPS is not saved to your profile."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": "https://app.locallist.biz",
        "asyncRoutes": true
      },
      "eas": {
        "projectId": "e3717536-736b-40a7-82b6-e4a00a8f1f7d"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e3717536-736b-40a7-82b6-e4a00a8f1f7d"
    }
  }
}
