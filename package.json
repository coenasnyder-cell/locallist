{
  "name": "myapp",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "verify:repo-root": "node ./scripts/verify-repo-root.js",
    "prestart": "npm run verify:repo-root",
    "start": "node --max-old-space-size=4096 ./node_modules/expo/bin/cli start",
    "prestart:clear": "npm run verify:repo-root",
    "start:clear": "node --max-old-space-size=4096 ./node_modules/expo/bin/cli start --clear",
    "prestart:dev-client": "npm run verify:repo-root",
    "start:dev-client": "node --max-old-space-size=8192 ./node_modules/expo/bin/cli start --dev-client",
    "prestart:dev-client:clear": "npm run verify:repo-root",
    "start:dev-client:clear": "node --max-old-space-size=8192 ./node_modules/expo/bin/cli start --dev-client --clear",
    "reset-project": "node ./scripts/reset-project.js",
    "preandroid": "npm run verify:repo-root",
    "android": "node --max-old-space-size=4096 ./node_modules/expo/bin/cli start --android",
    "preios": "npm run verify:repo-root",
    "ios": "node --max-old-space-size=4096 ./node_modules/expo/bin/cli start --ios",
    "preweb": "npm run verify:repo-root",
    "web": "node --max-old-space-size=4096 ./node_modules/expo/bin/cli start --web",
    "preeas:build:dev:android": "npm run verify:repo-root",
    "eas:build:dev:android": "npx eas build --platform android --profile development",
    "preeas:build:dev:ios": "npm run verify:repo-root",
    "eas:build:dev:ios": "npx eas build --platform ios --profile development",
    "preeas:build:preview:android": "npm run verify:repo-root",
    "eas:build:preview:android": "npx eas build --platform android --profile preview",
    "preeas:build:preview:ios": "npm run verify:repo-root",
    "eas:build:preview:ios": "npx eas build --platform ios --profile preview",
    "preeas:build:prod:android": "npm run verify:repo-root",
    "eas:build:prod:android": "npx eas build --platform android --profile production",
    "preeas:build:prod:ios": "npm run verify:repo-root",
    "eas:build:prod:ios": "npx eas build --platform ios --profile production",
    "preeas:update:preview": "npm run verify:repo-root",
    "eas:update:preview": "npx eas update --branch preview --message \"Preview OTA update\"",
    "preeas:update:production": "npm run verify:repo-root",
    "eas:update:production": "npx eas update --branch production --message \"Production OTA update\"",
    "prequality:check": "npm run verify:repo-root",
    "lint": "expo lint",
    "lint:fix": "expo lint --fix",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "type-check": "tsc --noEmit",
    "type-check:fix": "tsc --noEmit --skipLibCheck",
    "quality:check": "npm run type-check && npm run lint",
    "quality:fix": "npm run lint:fix && npm run type-check:fix",
    "quality:pre-release": "npm run quality:check && npm run test",
    "beta:readiness": "node scripts/beta-readiness-check.js",
    "release:step6": "npm run quality:pre-release && npm run beta:readiness",
    "release:step7": "npm run release:step6 && npm run beta:readiness"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-native-picker/picker": "2.11.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@stripe/stripe-react-native": "0.50.3",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "^15.0.8",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "firebase": "^12.9.0",
    "memoize-one": "^5.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-dropdown-picker": "^5.4.6",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "stripe": "^20.4.0",
    "whatwg-fetch": "^3.6.20"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "expo-module-scripts": "^5.0.8",
    "firebase-admin": "^13.6.1",
    "jest-expo": "~54.0.17",
    "typescript": "~5.9.2"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo"
  }
}
